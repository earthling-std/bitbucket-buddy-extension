# Copy to .env and load before deploy, or export in your shell.
# Setup: https://developer.chrome.com/docs/webstore/using_webstore_api

CHROME_WEBSTORE_CLIENT_ID=
CHROME_WEBSTORE_CLIENT_SECRET=
CHROME_WEBSTORE_REFRESH_TOKEN=

# Developer Dashboard → Account → Publisher ID
CHROME_WEBSTORE_PUBLISHER_ID=

# Item id (32 chars) from the store / developer console item URL
CHROME_WEBSTORE_EXTENSION_ID=

# Set to 1 to submit for review after upload
# CHROME_WEBSTORE_PUBLISH=1
